{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-app.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://your-backend-app.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads).*[^.])",
      "destination": "/index.html"
    }
  ]
}
